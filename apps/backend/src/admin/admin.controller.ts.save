import {
  Controller,
  Get,
  Patch,
  Param,
  UseGuards,
  Req,
} from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';
import { JwtAuthGuard } from '../auth/guards/jwt-auth.guard';
import { RolesGuard } from '../auth/guards/roles.guard';
import { Roles } from '../auth/decorators/roles.decorator';
import { Role, PaymentStatus, ApprovalStatus } from '@prisma/client';

@Controller('admin')
@UseGuards(JwtAuthGuard, RolesGuard)
@Roles(Role.ADMIN)
export class AdminController {
  constructor(private readonly prisma: PrismaService) {}

  // View all registrations
  @Get('registrations')
B  getAllRegistrations() {
    return this.prisma.programRegistration.findMany({
      include: {
        user: { select: { email: true } },
      },
      orderBy: { createdAt: 'desc' },
    });
  }

  // Mark payment as PAID
  @Patch('registrations/:id/mark-paid')
  markPaymentPaid(@Param('id') id: string) {
    return this.prisma.programRegistration.update({
      where: { id },
      data: {
  paymentStatus: PaymentStatus.PAID as PaymentStatus,
},


  // Approve registration
  @Patch('registrations/:id/approve')
  approve(@Param('id') id: string, @Req() req: any) {
    return this.prisma.programRegistration.update({
      where: { id },
      data: {
        approvalStatus: ApprovalStatus.APPROVED,
        approvedAt: new Date(),
        approvedBy: req.user.userId,
      },
    });
  }

  // Reject registration
  @Patch('registrations/:id/reject')
  reject(@Param('id') id: string, @Req() req: any) {
    return this.prisma.programRegistration.update({
      where: { id },
      data: {
        approvalStatus: ApprovalStatus.REJECTED,
        approvedAt: new Date(),
        approvedBy: req.user.userId,
      },
    });
  }
}

